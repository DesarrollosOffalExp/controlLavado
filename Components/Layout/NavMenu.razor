@* Barra de navegación. Es su propia isla interactiva (InteractiveServer) para que
   el menú hamburguesa funcione: el MainLayout se renderiza estático (SSR). *@
@rendermode InteractiveServer

<nav class="topbar">
    <div class="topbar-row">
        <div class="brand"><a href="@PortalUrl" class="brand-badge" title="Ir al inicio de Offal"><img src="favicon.png" alt="Offal" /></a>Control de Lavados</div>
        <button class="hamburger @(menuOpen ? "abierto" : "")" @onclick="ToggleMenu"
                aria-label="Menú" aria-expanded="@menuOpen">
            <span></span><span></span><span></span>
        </button>
    </div>
    <div class="nav-collapse @(menuOpen ? "abierto" : "")">
        <div class="links" @onclick="CerrarMenu">
            <NavLink class="navlink" href="/camiones" Match="NavLinkMatch.All">Camiones</NavLink>
            <NavLink class="navlink" href="/hielo">Fábrica de Hielo</NavLink>
            <NavLink class="navlink" href="/hiel">Hiel</NavLink>
            <NavLink class="navlink" href="/varias">Varias</NavLink>
            <AuthorizeView Roles="Admin,Administrativo">
                <NavLink class="navlink" href="/reportes">Reportes</NavLink>
                <NavLink class="navlink" href="/catalogos">Configuración</NavLink>
            </AuthorizeView>
            <AuthorizeView Roles="Admin">
                <NavLink class="navlink" href="/usuarios">Usuarios</NavLink>
            </AuthorizeView>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="userbox">
                    <span class="avatar">@Iniciales(context.User)</span>
                    <span class="userinfo">
                        <span class="user-name">@NombreUsuario(context.User)</span>
                        <span class="user-rol">@Rol(context.User)</span>
                    </span>
                    <a class="navlink salir" href="/logout">Cerrar sesión</a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    // Portal / index general de Offal. Actualizar si el portal cambia de dominio.
    private const string PortalUrl = "https://offal-hsb3c0gebjgbfmae.eastus-01.azurewebsites.net";

    private bool menuOpen;
    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CerrarMenu() => menuOpen = false;

    private static string NombreUsuario(System.Security.Claims.ClaimsPrincipal u)
        => u.FindFirst("name")?.Value ?? u.Identity?.Name ?? "Usuario";

    private static string Rol(System.Security.Claims.ClaimsPrincipal u)
        => u.IsInRole("Admin") ? "Admin"
         : u.IsInRole("Administrativo") ? "Administrativo"
         : "Operario";

    private static string Iniciales(System.Security.Claims.ClaimsPrincipal u)
    {
        var n = NombreUsuario(u).Trim();
        var partes = n.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        string ini = partes.Length >= 2
            ? $"{partes[0][0]}{partes[1][0]}"
            : (n.Length >= 2 ? n.Substring(0, 2) : n);
        return ini.ToUpperInvariant();
    }
}
