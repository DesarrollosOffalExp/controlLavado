@page "/usuarios"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using System.Globalization
@inject UsuarioService Svc
@inject GraphMailService Mail
@inject NavigationManager Nav

<PageTitle>Usuarios</PageTitle>

<header class="page-head">
    <h1>Usuarios</h1>
    <p>Invitá personas por correo y definí su perfil. La invitación crea la cuenta y le manda un link para entrar.</p>
</header>

<div class="panel">
    <section class="card">
        <h2>Invitar por correo</h2>
        <p class="muted" style="font-size:13px; margin:-4px 0 4px">Se crea la cuenta y se le envía un link para que defina su contraseña e ingrese.</p>
        <div class="form-grid">
            <label><span>Email</span><input @bind="nuevo.Email" placeholder="persona@email.com" /></label>
            <label><span>Nombre (opcional)</span><input @bind="nuevo.Nombre" /></label>
            <label><span>Rol</span>
                <select @bind="nuevo.Rol">
                    <option value="Operario">Operario</option>
                    <option value="Administrativo">Administrativo</option>
                    <option value="Admin">Administrador</option>
                </select>
            </label>
        </div>
        @if (error is not null) { <p class="error">@error</p> }
        <div class="curso-actions">
            <button class="btn btn-primary" @onclick="Invitar">Invitar</button>
        </div>
        @if (resultado is not null)
        {
            <div class="invite-result">
                <p>@resultado</p>
                @if (link is not null)
                {
                    <label><span>Link de invitación (copialo y enviáselo si hace falta)</span><input value="@link" readonly /></label>
                }
            </div>
        }
    </section>

    <section class="card">
        <h2>Usuarios (@usuarios.Count)</h2>
        <div class="tabla-scroll">
            <table class="grilla">
                <thead><tr><th>Email</th><th>Nombre</th><th>Rol</th><th>Estado</th><th>Último acceso</th><th></th></tr></thead>
                <tbody>
                    @foreach (var u in usuarios)
                    {
                        <tr style="@(u.Activo ? "" : "opacity:.5")">
                            <td>@u.Email</td>
                            <td>@u.Nombre</td>
                            <td>
                                <select value="@u.Rol" @onchange="e => CambiarRol(u.Id, e.Value?.ToString())">
                                    <option value="Operario">Operario</option>
                                    <option value="Administrativo">Administrativo</option>
                                    <option value="Admin">Administrador</option>
                                </select>
                            </td>
                            <td>@(u.Activo ? "Activo" : "Baja")</td>
                            <td>@(u.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm", Es) ?? "—")</td>
                            <td class="acciones">
                                <button class="btn btn-ghost" @onclick="() => ToggleActivo(u.Id)">@(u.Activo ? "Dar de baja" : "Activar")</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private static readonly CultureInfo Es = CultureInfo.GetCultureInfo("es-AR");
    private List<Usuario> usuarios = new();
    private Usuario nuevo = new();
    private string? error;
    private string? resultado;
    private string? link;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar() => usuarios = await Svc.ListarAsync();

    private async Task Invitar()
    {
        error = null; resultado = null; link = null;
        var (u, token, err) = await Svc.InvitarAsync(nuevo.Email, nuevo.Nombre, nuevo.Rol);
        if (u is null) { error = err; return; }

        link = $"{Nav.BaseUri}invitacion?token={token}";
        var html =
            $"<p>Te invitaron a <b>Control de Lavados</b>.</p>" +
            $"<p>Para activar tu cuenta y definir tu contraseña, entrá a este link:</p>" +
            $"<p><a href=\"{link}\">{link}</a></p>" +
            $"<p style=\"color:#888\">El link vence en 7 días.</p>";
        var enviado = await Mail.EnviarAsync(u.Email, "Invitación — Control de Lavados", html);
        resultado = enviado
            ? $"Listo: le enviamos el correo a {u.Email}."
            : $"Cuenta creada para {u.Email}. El envío automático de correos no está configurado todavía — copiá el link de abajo y enviáselo.";

        nuevo = new();
        await Cargar();
    }

    private async Task CambiarRol(int id, string? rol)
    {
        if (Enum.TryParse<RolUsuario>(rol, out var r)) { await Svc.CambiarRolAsync(id, r); await Cargar(); }
    }
    private async Task ToggleActivo(int id) { await Svc.ToggleActivoAsync(id); await Cargar(); }
}
