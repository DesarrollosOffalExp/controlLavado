@page "/login"
@using ControlLavados.Components.Layout
@layout LoginLayout
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using ControlLavados.Auth
@inject UsuarioService Usuarios
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IHostEnvironment Env

<PageTitle>Ingresar — Control de Lavados</PageTitle>

<div class="login-card">
    <div class="login-brand">
        <img src="favicon.png" alt="Offal" class="login-logo" />
        <div>
            <h1>Control de Lavados</h1>
            <p class="muted">Ingresá para continuar</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <p class="login-error">@error</p>
    }

    @if (EntraHabilitado)
    {
        <a class="btn btn-ms btn-block" href="MicrosoftIdentity/Account/SignIn">Iniciar sesión con Microsoft</a>
        <div class="login-sep"><span>o con tu email</span></div>
    }

    <EditForm Model="login" FormName="login" OnValidSubmit="Ingresar">
        <DataAnnotationsValidator />
        <label><span>Email</span><InputText @bind-Value="login.Email" autocomplete="username" placeholder="tu@email.com" /></label>
        <label><span>Contraseña</span><InputText type="password" @bind-Value="login.Password" autocomplete="current-password" /></label>
        <button class="btn btn-primary btn-block" type="submit">Ingresar</button>
    </EditForm>

    @if (EsDev)
    {
        <EditForm Model="dev" FormName="dev" OnValidSubmit="EntrarDemo">
            <button class="btn btn-ghost btn-block" type="submit" style="margin-top:12px">Entrar como admin (demo)</button>
        </EditForm>
    }
</div>

@code {
    [CascadingParameter] public HttpContext HttpContext { get; set; } = default!;
    [SupplyParameterFromForm(FormName = "login")] private LoginModel login { get; set; } = new();
    [SupplyParameterFromForm(FormName = "dev")] private DevModel dev { get; set; } = new();

    private string? error;

    protected override void OnInitialized()
    {
        // Las props [SupplyParameterFromForm] que no corresponden al form enviado
        // llegan en null; las reinicializamos para que sus EditForm no fallen.
        login ??= new();
        dev ??= new();
    }

    private bool EntraHabilitado => Config.GetValue<bool>("AzureAd:Enabled") && !Env.IsDevelopment();
    private bool EsDev => Env.IsDevelopment();

    private async Task Ingresar()
    {
        var u = await Usuarios.ValidarLocalAsync(login.Email, login.Password);
        if (u is null) { error = "Email o contraseña incorrectos."; return; }
        await IngresarConCookie(u);
    }

    private async Task EntrarDemo()
    {
        await IngresarConCookie(new Usuario { Email = "roberto.sanabria@offal.com.ar", Nombre = "Roberto Sanabria (demo)" });
    }

    private async Task IngresarConCookie(Usuario u)
    {
        await HttpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            Principales.CrearLocal(u),
            new AuthenticationProperties { IsPersistent = true });
        Nav.NavigateTo("/", forceLoad: true);
    }

    public class LoginModel
    {
        [Required] public string Email { get; set; } = "";
        [Required] public string Password { get; set; } = "";
    }

    public class DevModel { }
}
