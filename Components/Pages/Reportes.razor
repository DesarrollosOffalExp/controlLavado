@page "/reportes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Administrativo")]
@using System.Globalization
@inject ReporteService Rep
@inject CatalogoService Cat
@inject IJSRuntime JS

<PageTitle>Reportes</PageTitle>

<header class="page-head">
    <h1>Reportes <span class="info" tabindex="0" data-tip="@TipGeneral">i</span></h1>
    <p>Métricas por semana y turno, y exportación a Excel. Pasá el mouse por la <b>i</b> de cada reporte para ver qué calcula.</p>
</header>

<div class="panel">
    <section class="card">
        <div class="form-grid">
            <label>
                <span>Circuito</span>
                <select @bind="tipoSel" @bind:after="Cargar">
                    <option value="Camion">Camiones</option>
                    <option value="Hielo">Fábrica de Hielo</option>
                    <option value="Hiel">Hiel</option>
                    <option value="Varias">Varias</option>
                    <option value="Todos">Todos</option>
                </select>
            </label>
            <label>
                <span>Semana</span>
                <select @bind="semanaKey" @bind:after="Cargar">
                    @foreach (var s in semanas)
                    {
                        <option value="@s.Clave">@s.Etiqueta</option>
                    }
                </select>
            </label>
        </div>
        <div class="curso-actions">
            <button class="btn btn-primary" @onclick="Exportar" disabled="@(lavados.Count == 0)">Exportar a Excel</button>
        </div>
        <p class="muted" style="margin-top:10px">@ResumenTexto</p>
    </section>

    <section class="card">
        <h2>Nómina de la semana <span class="info" tabindex="0" data-tip="@TipNomina">i</span></h2>
        <div class="nomina-cifras">
            <div class="cifra">
                <span class="n">@nomina.Activos</span>
                <span class="lbl">Nómina activa</span>
            </div>
            <div class="cifra">
                <span class="n">@nomina.Trabajaron</span>
                <span class="lbl">Trabajaron</span>
            </div>
            <div class="cifra">
                <span class="n">@(nomina.Activos - nomina.Trabajaron)</span>
                <span class="lbl">No trabajaron</span>
            </div>
        </div>
    </section>

    @if (metricas.Count == 0)
    {
        <section class="card"><p class="muted">No hay datos para mostrar en la semana seleccionada.</p></section>
    }
    else
    {
        @foreach (var t in metricas)
        {
            <section class="card">
                <h2>@(t.Turno == "Resumen" ? "Resumen (total)" : "Turno " + t.Turno) <span class="info" tabindex="0" data-tip="@TipMetricas">i</span></h2>
                <div class="tabla-scroll">
                    <table class="grilla grilla-center">
                        <thead>
                            <tr>
                                <th>Semana</th>
                                @if (MostrarCantidad)
                                {
                                    <th>Lavados</th>
                                }
                                <th>Total hs</th>
                                <th>Neto hs</th>
                                <th>Prom. hs</th>
                                <th>Operarios</th>
                                <th>Prom. op.</th>
                                <th>% Var. hs</th>
                                @if (MostrarCantidad)
                                {
                                    <th>% Var. lavados</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in t.Semanas)
                            {
                                <tr>
                                    <td class="num">@s.Semana</td>
                                    @if (MostrarCantidad)
                                    {
                                        <td class="num">@s.Lavados</td>
                                    }
                                    <td class="num">@FmtDur(s.TotalHoras)</td>
                                    <td class="num">@FmtDur(s.HorasNetas)</td>
                                    <td class="num">@FmtDur(s.PromedioHoras)</td>
                                    <td class="num">@s.TotalOperarios</td>
                                    <td class="num">@s.PromedioOperarios.ToString("0.0", Es)</td>
                                    <td class="num">@FmtVar(s.VarHoras)</td>
                                    @if (MostrarCantidad)
                                    {
                                        <td class="num">@FmtVar(s.VarLavados)</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (MostrarCantidad && frigorificos.Count > 0)
        {
            <section class="card">
                <h2>Lavados por frigorífico <span class="info" tabindex="0" data-tip="@TipFrigorifico">i</span></h2>
                <div class="tabla-scroll">
                    <table class="grilla grilla-center">
                        <thead><tr><th>Frigorífico</th><th>Lavados</th></tr></thead>
                        <tbody>
                            @foreach (var f in frigorificos)
                            {
                                <tr>
                                    <td>@f.Frigorifico</td>
                                    <td class="num">@f.Cantidad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        <section class="card">
            <h2>Horas por operario <span class="info" tabindex="0" data-tip="@TipHoras">i</span></h2>
            @if (horas.Filas.Count == 0)
            {
                <p class="muted">Sin operarios en la semana.</p>
            }
            else
            {
                <div class="tabla-scroll">
                    <table class="grilla grilla-center">
                        <thead>
                            <tr>
                                <th>Turno</th>
                                <th>Operario</th>
                                <th>Tipo</th>
                                @foreach (var sem in horas.Semanas)
                                {
                                    <th>Sem @sem hs</th>
                                    <th>Sem @sem d</th>
                                }
                                <th>Días trab.</th>
                                <th>Total hs</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in horas.Filas)
                            {
                                <tr>
                                    <td>@f.Turno</td>
                                    <td>@f.Operario</td>
                                    <td>@f.Tipo</td>
                                    @foreach (var sem in horas.Semanas)
                                    {
                                        var hs = f.PorSemana.TryGetValue(sem, out var h) ? h : TimeSpan.Zero;
                                        var d = f.DiasPorSemana.TryGetValue(sem, out var dd) ? dd : 0;
                                        <td class="num">@FmtDur(hs)</td>
                                        <td class="num">@d</td>
                                    }
                                    <td class="num">@f.DiasTrabajados</td>
                                    <td class="num"><b>@FmtDur(f.Total)</b></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>

@code {
    private static readonly CultureInfo Es = CultureInfo.GetCultureInfo("es-AR");

    // Textos de ayuda (tooltips) de cada reporte.
    private const string TipGeneral =
        "Todos los reportes usan SOLO lavados/tareas finalizados de la SEMANA seleccionada (la variación se calcula contra la semana anterior, que no se muestra).\n\n" +
        "• Tiempo total: Camión = Desatraco − Atraco; Hielo/Hiel/Varias = Fin − Inicio.\n" +
        "• Turno: Mañana 06:00–18:59, Tarde el resto.\n" +
        "• Las TAREAS (Hielo/Hiel/Varias) NO se cuentan como cantidad; solo aportan su tiempo.";

    private const string TipMetricas =
        "Métricas de la semana seleccionada. El % Var. compara contra la semana anterior. Un bloque por turno (Mañana / Tarde) y un bloque «Resumen».\n\n" +
        "• Lavados: cantidad de camiones (las tareas no se cuentan). Se oculta en circuitos de tareas.\n" +
        "• Total hs: suma de los tiempos; Neto hs: solo el lavado (Fin − Inicio); Prom. hs: ÷ registros.\n" +
        "• Operarios: personas DISTINTAS que trabajaron.\n" +
        "• % Var.: variación vs la semana anterior.";

    private const string TipFrigorifico =
        "Cantidad de lavados de camión agrupados por frigorífico, en la semana seleccionada (de mayor a menor).";

    private const string TipNomina =
        "Contraste de la semana: cuántos operarios ACTIVOS hay en la nómina (Personal) y cuántos de ellos " +
        "efectivamente trabajaron o hicieron tareas esa semana (en cualquier circuito).";

    private const string TipHoras =
        "Horas trabajadas por cada operario en la semana.\n\n" +
        "• «hs» horas trabajadas y «d» días trabajados.\n" +
        "• Total hs: suma de la semana.";

    private string tipoSel = "Camion";
    private string semanaKey = "";

    private List<Lavado> lavados = new();
    private List<MetricasTurno> metricas = new();
    private HorasReporte horas = new(new(), new());
    private List<FrigorificoCant> frigorificos = new();
    private NominaSemana nomina = new(0, 0);
    private Dictionary<string, string?> turnoOperarios = new();

    private List<OpcionSemana> semanas = new();
    private record OpcionSemana(string Clave, DateOnly Lunes, string Etiqueta);

    // La columna de cantidad (lavados) solo aplica a camiones; en tareas se oculta.
    private bool MostrarCantidad => tipoSel is "Camion" or "Todos";

    private string ResumenTexto
    {
        get
        {
            int lav = lavados.Count(l => l.Tipo == TipoLavado.Camion);
            int tar = lavados.Count(l => l.Tipo != TipoLavado.Camion);
            return tipoSel switch
            {
                "Camion" => $"{lav} lavados en la semana.",
                "Todos" => $"{lav} lavados y {tar} tareas en la semana (las tareas no se contabilizan como cantidad, solo su tiempo).",
                _ => $"{tar} tareas en la semana — solo se contabiliza el tiempo, no la cantidad.",
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        ConstruirSemanas();
        await Cargar();
    }

    // Últimas 16 semanas (ISO), de la más reciente a la más antigua.
    private void ConstruirSemanas()
    {
        var hoy = DateOnly.FromDateTime(DateTime.Today);
        int diffLunes = ((int)hoy.DayOfWeek + 6) % 7; // días desde el lunes
        var lunesActual = hoy.AddDays(-diffLunes);

        semanas = Enumerable.Range(0, 16)
            .Select(i => lunesActual.AddDays(-7 * i))
            .Select(lunes =>
            {
                var num = ISOWeek.GetWeekOfYear(lunes.ToDateTime(TimeOnly.MinValue));
                var domingo = lunes.AddDays(6);
                var clave = lunes.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                return new OpcionSemana(clave, lunes, $"Semana {num} ({lunes:dd/MM}–{domingo:dd/MM})");
            })
            .ToList();

        if (string.IsNullOrEmpty(semanaKey) && semanas.Count > 0)
            semanaKey = semanas[0].Clave;
    }

    private TipoLavado? TipoSeleccion() => tipoSel switch
    {
        "Camion" => TipoLavado.Camion,
        "Hielo" => TipoLavado.Hielo,
        "Hiel" => TipoLavado.Hiel,
        "Varias" => TipoLavado.Varias,
        _ => null,
    };

    private async Task Cargar()
    {
        var lunes = DateOnly.ParseExact(semanaKey, "yyyy-MM-dd", CultureInfo.InvariantCulture);
        var domingo = lunes.AddDays(6);
        var lunesPrev = lunes.AddDays(-7);

        // Mapa operario -> turno asignado (para agrupar "Horas por operario").
        turnoOperarios = new(StringComparer.OrdinalIgnoreCase);
        var operarios = await Cat.OperariosAsync();
        foreach (var o in operarios)
            turnoOperarios[o.NombreCompleto] = o.Turno;

        // Se carga la semana anterior solo para calcular la variación, pero NO se muestra:
        // la tabla exhibe únicamente la fila de la semana pedida.
        var conPrev = await Rep.ObtenerAsync(TipoSeleccion(), lunesPrev, domingo);
        var semNum = ISOWeek.GetWeekOfYear(lunes.ToDateTime(TimeOnly.MinValue));
        metricas = Rep.CalcularMetricas(conPrev)
            .Select(t => t with { Semanas = t.Semanas.Where(s => s.Semana == semNum).ToList() })
            .Where(t => t.Semanas.Count > 0)
            .ToList();

        lavados = conPrev.Where(l => l.Fecha >= lunes).ToList();
        horas = Rep.CalcularHorasPorOperario(lavados, turnoOperarios);
        frigorificos = Rep.LavadosPorFrigorifico(lavados);

        // Nómina: activos totales vs cuántos trabajaron en cualquier circuito esa semana.
        var todosSemana = await Rep.ObtenerAsync(null, lunes, domingo);
        var activos = operarios.Where(o => o.Activo).Select(o => o.NombreCompleto);
        nomina = Rep.NominaContraste(activos, todosSemana);
    }

    private async Task Exportar()
    {
        var bytes = Rep.GenerarExcel(lavados, metricas, TipoSeleccion(), turnoOperarios);
        var b64 = Convert.ToBase64String(bytes);
        var nombre = $"reporte-lavados-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
        await JS.InvokeVoidAsync("descargarArchivo", nombre, b64,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private static string FmtDur(TimeSpan t) => $"{(int)t.TotalHours}:{t.Minutes:00}:{t.Seconds:00}";
    private static string FmtVar(double? v) => v.HasValue ? v.Value.ToString("P1", Es) : "—";
}
